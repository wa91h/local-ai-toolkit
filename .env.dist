# Services — remove a name from the list to disable that service
# Available: litellm, n8n, openwebui
# Note: disabling litellm also requires removing openwebui (it depends on litellm)
COMPOSE_PROFILES=litellm,n8n,openwebui

# Postgres
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# LiteLLM
LITELLM_MASTER_KEY=sk-***
LITELLM_SALT_KEY=sk-***
OLLAMA_API_KEY=<YOUR_OLLAMA_API_KEY>

# N8N
TZ=<YOUR_TIMEZONE>
